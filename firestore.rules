rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /metadata/globalStats {
      allow get: if true;
      allow list: if false;
    }

    match /visions/{visionId} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && (request.auth.uid == resource.data.ownerId || request.auth.uid == request.resource.data.ownerId);
      allow list: if false; 
    }

    match /users/{userId} {
      allow get, create, update, delete: if isOwner(userId);

      match /photoBoothSessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}