rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces Path-Based Ownership for user data and public readability 
     * for shared assets (visions) and global metadata.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Rules ---

    /** 
     * @description Publicly readable metadata for global stats (e.g., video count). 
     */
    match /metadata/{docId} {
      allow get, list: if true;
      allow write: if false;
    }

    /**
     * @description Publicly readable collection for shared AI visions.
     */
    match /visions/{visionId} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      // Allow the owner to update the document with video metadata
      allow update: if isSignedIn() && (request.auth.uid == resource.data.ownerId || request.auth.uid == request.resource.data.ownerId);
      allow list: if false; 
    }

    match /users/{userId} {
      allow get, create, update, delete: if isOwner(userId);

      match /photoBoothSessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Global Deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}