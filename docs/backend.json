{
  "entities": {
    "PhotoBoothSession": {
      "title": "PhotoBoothSession",
      "description": "Represents a single user's interaction session, including captured photo and generated cinematic video.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageData": { "type": "string", "description": "Base64 encoded polaroid image." },
        "activity": { "type": "string" },
        "theme": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" },
        "videoUrl": { "type": "string", "format": "uri", "description": "URL to the generated MP4 in storage." },
        "hasVideo": { "type": "boolean", "description": "Flag indicating if a video exists." }
      },
      "required": ["imageData", "activity", "theme", "createdAt", "ownerId"]
    },
    "GlobalMetadata": {
      "title": "GlobalMetadata",
      "description": "Tracking document for application-wide statistics.",
      "type": "object",
      "properties": {
        "videoCount": { "type": "number", "description": "Total number of videos generated." }
      }
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/visions/{visionId}": {
      "schema": { "$ref": "#/backend/entities/PhotoBoothSession" },
      "description": "Publicly shared AI visions."
    },
    "/metadata/{docId}": {
      "schema": { "$ref": "#/backend/entities/GlobalMetadata" },
      "description": "Global usage statistics and application metadata."
    }
  }
}
