{
  "entities": {
    "PhotoBoothSession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PhotoBoothSession",
      "type": "object",
      "description": "Represents a single user's interaction session with the Free-Time Machine photo booth.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the PhotoBoothSession entity."
        },
        "imageData": {
          "type": "string",
          "description": "Base64 encoded image data for the final Polaroid vision."
        },
        "activity": {
          "type": "string",
          "description": "The specific activity depicted in the vision."
        },
        "theme": {
          "type": "string",
          "description": "The theme category of the vision."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the vision was created."
        },
        "ownerId": {
          "type": "string",
          "description": "UID of the user who owns this vision."
        }
      },
      "required": [
        "imageData",
        "activity",
        "theme",
        "createdAt",
        "ownerId"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/photoBoothSessions/{sessionId}",
        "definition": {
          "entityName": "PhotoBoothSession",
          "schema": {
            "$ref": "#/backend/entities/PhotoBoothSession"
          },
          "description": "Stores detailed photo booth sessions, owned by the user.",
          "params": [
            {
              "name": "userId",
              "description": "UID of the user."
            },
            {
              "name": "sessionId",
              "description": "Unique session ID."
            }
          ]
        }
      },
      {
        "path": "/visions/{visionId}",
        "definition": {
          "entityName": "PhotoBoothSession",
          "schema": {
            "$ref": "#/backend/entities/PhotoBoothSession"
          },
          "description": "Stores shared AI visions.",
          "params": [
            {
              "name": "visionId",
              "description": "Unique identifier for the shared vision."
            }
          ]
        }
      }
    ]
  }
}